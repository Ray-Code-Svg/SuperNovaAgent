{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StreamOpenRequest",
  "type": "object",
  "properties": {
    "after_event_id": {
      "type": [
        "integer",
        "null"
      ],
      "format": "int64"
    },
    "lane": {
      "anyOf": [
        {
          "$ref": "#/definitions/MessageLane"
        },
        {
          "type": "null"
        }
      ]
    },
    "limit": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0.0
    },
    "request_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "definitions": {
    "MessageLane": {
      "type": "string",
      "enum": [
        "chat",
        "task",
        "runtime"
      ]
    }
  }
}