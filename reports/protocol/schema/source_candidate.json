{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SourceCandidate",
  "type": "object",
  "required": [
    "item",
    "selected",
    "source_kind"
  ],
  "properties": {
    "detail": {
      "type": [
        "string",
        "null"
      ]
    },
    "item": {
      "$ref": "#/definitions/ContextPackItem"
    },
    "selected": {
      "type": "boolean"
    },
    "source_kind": {
      "type": "string"
    }
  },
  "definitions": {
    "ContextPackItem": {
      "type": "object",
      "required": [
        "include_mode",
        "item_kind",
        "priority",
        "ref_id"
      ],
      "properties": {
        "include_mode": {
          "type": "string"
        },
        "item_kind": {
          "type": "string"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "ref_id": {
          "type": "string"
        }
      }
    }
  }
}