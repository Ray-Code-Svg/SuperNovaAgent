{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChatThreadRecord",
  "type": "object",
  "required": [
    "chat_thread_id",
    "container_id",
    "created_at_ms",
    "title",
    "updated_at_ms"
  ],
  "properties": {
    "chat_thread_id": {
      "type": "string"
    },
    "container_id": {
      "type": "string"
    },
    "created_at_ms": {
      "type": "integer",
      "format": "uint128",
      "minimum": 0.0
    },
    "title": {
      "type": "string"
    },
    "updated_at_ms": {
      "type": "integer",
      "format": "uint128",
      "minimum": 0.0
    }
  }
}