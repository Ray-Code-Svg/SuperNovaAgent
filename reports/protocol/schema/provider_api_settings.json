{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProviderApiSettings",
  "type": "object",
  "required": [
    "providers"
  ],
  "properties": {
    "providers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProviderApiRecord"
      }
    }
  },
  "definitions": {
    "ProviderApiRecord": {
      "type": "object",
      "required": [
        "api_key_configured",
        "provider"
      ],
      "properties": {
        "api_base_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "api_key_configured": {
          "type": "boolean"
        },
        "credential_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider": {
          "type": "string"
        },
        "token_usage_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "validation_status": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}