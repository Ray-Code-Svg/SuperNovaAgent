{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContextPack",
  "type": "object",
  "required": [
    "auto_policy",
    "container_id",
    "context_pack_id",
    "excluded_items",
    "selected_items"
  ],
  "properties": {
    "auto_policy": {
      "$ref": "#/definitions/ContextPackAutoPolicy"
    },
    "container_id": {
      "type": "string"
    },
    "context_pack_id": {
      "type": "string"
    },
    "estimated_tokens": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "excluded_items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ContextPackItem"
      }
    },
    "selected_items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ContextPackItem"
      }
    },
    "summary_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "definitions": {
    "ContextPackAutoPolicy": {
      "type": "object",
      "required": [
        "include_recent_chat_turns",
        "include_recent_tasks",
        "prefer_summaries"
      ],
      "properties": {
        "include_recent_chat_turns": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "include_recent_tasks": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "prefer_summaries": {
          "type": "boolean"
        }
      }
    },
    "ContextPackItem": {
      "type": "object",
      "required": [
        "include_mode",
        "item_kind",
        "priority",
        "ref_id"
      ],
      "properties": {
        "include_mode": {
          "type": "string"
        },
        "item_kind": {
          "type": "string"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "ref_id": {
          "type": "string"
        }
      }
    }
  }
}