{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtifactRecord",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "container_id",
    "created_at_ms",
    "status",
    "title",
    "verified"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string"
    },
    "capability_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "container_id": {
      "type": "string"
    },
    "created_at_ms": {
      "type": "integer",
      "format": "uint128",
      "minimum": 0.0
    },
    "kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "receipt_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string"
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "verified": {
      "type": "boolean"
    }
  }
}